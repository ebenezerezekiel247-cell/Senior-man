{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "Session": {
      "title": "Chat Session",
      "description": "Metadata for a chat conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "ai"] },
        "text": { "type": "string" },
        "image": {
          "type": "object",
          "properties": {
            "url": { "type": "string" },
            "mimeType": { "type": "string" }
          }
        },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Stores session metadata for a specific user"
    },
    "/users/{userId}/sessions/{sessionId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Stores individual messages within a session"
    }
  }
}
